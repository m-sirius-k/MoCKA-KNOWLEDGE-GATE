# MoCKA-GATE Gateway Configuration
# Staging Environment Template

NODE_ENV=staging
PORT=8080
BASE_URL=https://staging.gateway.mocka.example.com

# JWT Configuration
JWT_ALG=HS256
JWT_SECRET_BASE64=REPLACE_WITH_BASE64_SECRET
JWT_TTL_SECONDS=300

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Logging
LOG_LEVEL=info

# CORS
CORS_ALLOW_ORIGINS=*

# BigQuery Audit Logging
BQS_PROJECT=mocka-audit
BQS_DATASET=gateway_logs
BQS_TABLE=intent_requests
