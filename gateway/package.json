{
  "name": "mocka-gate",
  "version": "1.0.0",
  "description": "MoCKA-GATE: Gemini/Copilot Intent-Driven HTTP Gateway",
  "main": "src/server.ts",
  "scripts": {
    "start": "ts-node src/server.ts",
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/server.ts",
    "token:gemini": "ts-node scripts/issue_token.ts gemini",
    "token:copilot": "ts-node scripts/issue_token.ts copilot"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.0.0",
    "jsonwebtoken": "^9.1.0",
    "joi": "^17.11.0",
    "pino": "^8.17.0",
    "pino-http": "^9.0.0",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
